---
import type { ImageMetadata } from 'astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import type { Lang } from '../../i18n/ui';
import { selectPostSocialImage } from '../../lib/social-preview';

const lang: Lang = 'zh';
export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post: CollectionEntry<'blog'>) => ({
		params: { slug: post.id },
		props: post,
	}));
}

const post = Astro.props as CollectionEntry<'blog'>;
const { Content, headings } = await render(post);

const heroImage = post.data.heroImage as ImageMetadata | undefined;
const ogImage = selectPostSocialImage(
	{ ...post, data: { ...post.data, heroImage } },
	lang,
);
---

<BlogPost {...post.data} headings={headings} heroImage={heroImage} ogImage={ogImage} lang={lang} slug={post.id}>
	<Content />
</BlogPost>
