---
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import BlogList from '../layouts/BlogList.astro';
import { getBlogCollection } from '../i18n/collections';
import type { Lang } from '../i18n/ui';

const lang: Lang = 'zh';
const collectionName = getBlogCollection(lang);

const allPosts = (await getCollection(collectionName as any)).sort(
	(a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function getExcerptHtml(body: string): { html: string; hasMore: boolean } {
	const moreMarker = '<!--more-->';
	const moreIndex = body.indexOf(moreMarker);

	if (moreIndex > 0) {
		const excerptMd = body.substring(0, moreIndex).trim();
		return {
			html: marked.parse(excerptMd) as string,
			hasMore: true,
		};
	}

	const paragraphs = body.split(/\n\n+/);
	const firstFewParagraphs = paragraphs.slice(0, 3).join('\n\n');

	return {
		html: marked.parse(firstFewParagraphs) as string,
		hasMore: paragraphs.length > 3 || body.length > firstFewParagraphs.length + 100,
	};
}

const postsPerPage = 10;
const totalPages = Math.ceil(allPosts.length / postsPerPage);
const paginatedPosts = allPosts.slice(0, postsPerPage).map((post: any) => ({
	post,
	excerpt: getExcerptHtml(post.body || ''),
}));
---

<BlogList lang={lang} currentPage={1} totalPages={totalPages} posts={paginatedPosts} />
