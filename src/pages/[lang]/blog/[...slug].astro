---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';
import { getBlogCollection, nonDefaultLocales } from '../../../i18n/collections';
import type { Lang } from '../../../i18n/ui';
import { selectPostSocialImage } from '../../../lib/social-preview';

export async function getStaticPaths() {
	const paths = [];
	for (const lang of nonDefaultLocales) {
		const posts = await getCollection(getBlogCollection(lang) as any);
		for (const post of posts as any[]) {
			paths.push({
				params: { lang, slug: post.id },
				props: { post, lang },
			});
		}
	}
	return paths;
}

const { post, lang } = Astro.props as { post: any; lang: Lang };
const { Content, headings } = await render(post);

const ogImage = selectPostSocialImage(post, lang);
---

<BlogPost {...post.data} headings={headings} heroImage={post.data.heroImage} ogImage={ogImage} lang={lang} slug={post.id}>
	<Content />
</BlogPost>
